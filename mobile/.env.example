# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Golf Course API ───────────────────────────────────────────────────────────
# Sign up at golfcourseapi.com or golfbert.com — PM to supply
# Leave blank to use built-in mock data during development
EXPO_PUBLIC_COURSE_API_URL=https://api.golfcourseapi.com/v1
EXPO_PUBLIC_COURSE_API_KEY=your_course_api_key_here

# ── Phase 2 (voice + GHIN) — not needed until Phase 2 ────────────────────────
# EXPO_PUBLIC_GHIN_CLIENT_ID=
# EXPO_PUBLIC_GHIN_CLIENT_SECRET=
# ANTHROPIC_API_KEY=   <-- server-side only, goes in Supabase Vault
